# ─── Application ─────────────────────────────────────
APP_ENV=development
APP_PORT=8080

# ─── JWT ──────────────────────────────────────────────
# Secret for signing tokens. At least 16 characters.
# In production, set a strong random value.
JWT_SECRET=find-your-job-dev-secret-change-in-production
# Token lifetimes
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ─── PostgreSQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=findyourjob
DB_SSLMODE=disable

# ─── Connection Pool ──────────────────────────────────
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
